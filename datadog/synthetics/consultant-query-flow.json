{
  "name": "InfraAdvisor — Consultant Query Flow",
  "type": "browser",
  "status": "live",
  "message": "InfraAdvisor UI is not responding correctly to the Texas bridge query.\n\nSteps:\n1. Navigate to the UI\n2. Submit the Texas bridge query\n3. Assert response contains 'bridge' and a structure number\n\n@slack-infra-advisor-alerts",
  "tags": ["team:infra-advisor", "env:dev"],
  "config": {
    "variables": [],
    "setCookie": "",
    "request": {
      "url": "{{UI_BASE_URL}}",
      "headers": {}
    }
  },
  "options": {
    "tick_every": 300,
    "min_failure_duration": 0,
    "min_location_failed": 1,
    "retry": {
      "count": 1,
      "interval": 5000
    },
    "monitor_options": {
      "notify_audit": false,
      "renotify_interval": 120
    },
    "ignoreServerCertificateError": false,
    "disableCsp": false,
    "enableProfiling": false,
    "enableSecurityTesting": false,
    "device_ids": ["laptop_large"],
    "locations": ["aws:us-east-1"]
  },
  "steps": [
    {
      "name": "Navigate to InfraAdvisor UI",
      "type": "goToUrl",
      "params": {
        "value": "{{UI_BASE_URL}}"
      }
    },
    {
      "name": "Wait for chat input to be visible",
      "type": "waitForElement",
      "params": {
        "element": {
          "userLocator": {
            "values": [
              {
                "type": "css",
                "value": "[data-testid='chat-input']"
              }
            ]
          },
          "operator": "isVisible"
        }
      }
    },
    {
      "name": "Type Texas bridge query into chat input",
      "type": "typeText",
      "params": {
        "element": {
          "userLocator": {
            "values": [
              {
                "type": "css",
                "value": "[data-testid='chat-input']"
              }
            ]
          }
        },
        "value": "Pull all structurally deficient bridges in Texas with ADT over 10,000 and last inspection before 2022."
      }
    },
    {
      "name": "Submit query",
      "type": "click",
      "params": {
        "element": {
          "userLocator": {
            "values": [
              {
                "type": "css",
                "value": "[data-testid='send-button']"
              }
            ]
          }
        }
      }
    },
    {
      "name": "Wait for agent response (up to 30 seconds)",
      "type": "waitForElement",
      "params": {
        "element": {
          "userLocator": {
            "values": [
              {
                "type": "css",
                "value": "[data-testid='ai-message']"
              }
            ]
          },
          "operator": "isVisible"
        },
        "delay": 30000
      }
    },
    {
      "name": "Assert response contains 'bridge'",
      "type": "assertElementContent",
      "params": {
        "element": {
          "userLocator": {
            "values": [
              {
                "type": "css",
                "value": "[data-testid='ai-message']:last-child"
              }
            ]
          }
        },
        "operator": "contains",
        "value": "bridge"
      }
    },
    {
      "name": "Assert response contains a structure number (15-digit pattern)",
      "type": "assertCurrentUrl",
      "params": {
        "check": "bodyContainsRegex",
        "value": "\\d{7,15}"
      }
    }
  ]
}
