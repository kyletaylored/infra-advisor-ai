# Copy to .env (or set in shell) before running.
#
# The POC is vendor-neutral — it speaks pure OTLP. All backend-specific
# routing (credentials, dataset selection, LLMObs routing headers, …)
# belongs in the collector config under experiments/otel-collector/,
# not here.

# LLM provider (Azure OpenAI in this POC)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# OTLP target. Defaults to http://localhost:4318 (the local collector
# in experiments/otel-collector/). Point at any other OTLP HTTP endpoint
# to send somewhere else — no code changes required.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Optional resource attribute metadata
OTEL_SERVICE_NAME=otel-genai-poc
OTEL_SERVICE_VERSION=1.0.0
OTEL_DEPLOYMENT_ENV=dev
