# Copy to .env and fill in. Then export them before `dotnet run`:
#   set -a; source .env; set +a; dotnet run

# Azure OpenAI (same values as the main agent-api-dotnet service)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# Datadog OTLP LLMObs ingestion. Use the same DD_API_KEY as the main service.
DD_API_KEY=REPLACE_ME
DD_SITE=us3.datadoghq.com

# Optional: Datadog RUM (browser SDK). Leave empty to disable RUM in the UI.
DD_RUM_APPLICATION_ID=
DD_RUM_CLIENT_TOKEN=

# Optional metadata
OTEL_SERVICE_NAME=infra-advisor-otel-poc
DD_ENV=dev
DD_VERSION=1.0.0
