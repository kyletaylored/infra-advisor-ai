# Same env vars as the M.E.AI-only POC. The Makefile target
# (run-otel-poc-autoinstr) handles the OTEL_DOTNET_AUTO_* +
# CORECLR_* env vars for you by sourcing ~/.otel-dotnet-auto/instrument.sh
# before invoking `dotnet run`, so you don't need to set them here.

# LLM provider
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# OTLP target — defaults to the local collector
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Optional resource metadata. Defaults work fine.
OTEL_SERVICE_NAME=otel-genai-poc-autoinstr
OTEL_SERVICE_VERSION=1.0.0
OTEL_DEPLOYMENT_ENV=dev

# Optional: Datadog RUM browser keys. Picked up automatically by the
# Makefile from the root .env's VITE_DD_RUM_* vars when present.
DD_RUM_APPLICATION_ID=
DD_RUM_CLIENT_TOKEN=
DD_SITE=us3.datadoghq.com
