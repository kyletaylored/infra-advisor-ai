# Microsoft Agents Framework (MAF) POC env vars.
# Same shape as experiments/dotnet-otel-poc/.env.example — service name
# is the only meaningful difference.

# LLM provider (Azure OpenAI)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# OTLP target — defaults to the local collector
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# MCP server URL — defaults to a port-forwarded mcp-server-dotnet.
# Run this in another terminal before `make otel-maf-poc`:
#   kubectl port-forward -n infra-advisor svc/mcp-server-dotnet 8000:8000
MCP_SERVER_URL=http://localhost:8000/mcp

# Optional resource metadata
OTEL_SERVICE_NAME=infra-advisor-maf-poc
OTEL_SERVICE_VERSION=1.0.0
OTEL_DEPLOYMENT_ENV=dev

# Optional: DD RUM (browser SDK) — usually inherited from root .env's VITE_DD_RUM_*
DD_RUM_APPLICATION_ID=
DD_RUM_CLIENT_TOKEN=
DD_SITE=us3.datadoghq.com
